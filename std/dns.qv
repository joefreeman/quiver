'ip = IPv4['bin] | IPv6['bin];

[
  resolve: #Str['bin] {
    .0
    ~> __dns_resolve__ [~]
    ~> =resolver,
    %iter.unfold [resolver, #\DnsResolver {
      =r,
      __dns_next__ [r] ~> {
        | / => {
          __dns_close__ [r],
          []
        }
        | =b ~> {
          b
          ~> __binary_length__
          ~> {
            | =4 => IPv4[b]
            | =16 => IPv6[b]
          }
          ~> [~, r]
        }
      }
    }]
  }
]
